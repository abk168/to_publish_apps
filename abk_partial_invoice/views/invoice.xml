<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.ui.view" id="payment_inv_inherited">
            <field name="name">sale.advance.payment.inv</field>
            <field name="model">sale.advance.payment.inv</field>
            <field name="inherit_id" ref="sale.view_sale_advance_payment_inv"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='advance_payment_method']" position="before">
                    <field name="abk_picking_id" domain="abk_picking_id_domain" invisible="abk_amount == 0.0"/>
                    <field name="abk_picking_id_domain" invisible="1"/>
                    <field name="abk_picking_ids" widget="many2many_tags" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='advance_payment_method']" position="after">
                    <field name="abk_amount" invisible="advance_payment_method != 'custom_fixed'" readonly="1"/>
                    <field name="abk_fixed_amount"
                           invisible="advance_payment_method != 'custom_fixed' or abk_amount == 0.0" readonly="0"/>
                    <field name="abk_amount_to_invoice" invisible="abk_amount == 0.0" readonly="0"/>
                </xpath>
            </field>
        </record>
        <record id="view_invoice_inherit_abk_form" model="ir.ui.view">
            <field name="name">account.move.form.inherit.abk</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="after">
                    <field name="abk_invoiced_percentage" invisible="0"/>
                    <field name="abk_is_deposit"/>
                    <field name="abk_less_deposit"/>
                    <field name="abk_receive_data"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='name']" position="before">
                    <field name="abk_description_new"/>
                </xpath>
                <xpath expr="//field[@name='payment_reference']" position="after">
                    <field name="abk_dn_no"/>
                    <field name="abk_sales_order"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                    <page string="DN Items" name="abk_related_stock_moves">
                        <group>
                            <field name="abk_related_stock_moves" string="">
                                <tree string="DN Items">
                                    <field name="abk_related_move_id"/>
                                </tree>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>


        <record id="view_out_invoice_tree_inherit_abk" model="ir.ui.view">
            <field name="name">account.move.tree.inherit.abk</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="invoice_date_due" position="after">
                    <field name="abk_receive_data"/>
                </field>
            </field>
        </record>

        <record model="ir.actions.server" id="action_move_abk_move">
            <field name="name">Receive Invoice</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                action = records.action_update_receive_date()
            </field>
        </record>


    </data>
</odoo>
